<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:WhisperOfflineApp.ViewModels"
             x:Class="WhisperOfflineApp.Views.LoginPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource PageBackground}">

    <Grid RowDefinitions="2*, Auto, 1.5*" Padding="32">

        <!-- Logo + Titlu -->
        <VerticalStackLayout Grid.Row="0" VerticalOptions="End" Spacing="12"
                             Padding="0,0,0,32">
            <!-- Cercul cu icon -->
            <Border StrokeThickness="0" WidthRequest="100" HeightRequest="100"
                    HorizontalOptions="Center" BackgroundColor="{StaticResource SurfaceElevated}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="50"/>
                </Border.StrokeShape>
                <Label Text="🎙️" FontSize="48" 
                       HorizontalOptions="Center" VerticalOptions="Center"/>
            </Border>
            
            <Label Text="Whisper Offline" 
                   FontSize="30" FontAttributes="Bold"
                   TextColor="{StaticResource TextPrimary}" 
                   HorizontalOptions="Center"/>
            <Label Text="Transcriere vocală 100% locală" 
                   FontSize="14" TextColor="{StaticResource TextSecondary}" 
                   HorizontalOptions="Center"/>
        </VerticalStackLayout>

        <!-- Form -->
        <VerticalStackLayout Grid.Row="1" Spacing="16">

            <!-- Error message -->
            <Border BackgroundColor="#2D1215" Stroke="{StaticResource AccentRed}" 
                    StrokeThickness="1" IsVisible="{Binding HasError}" Padding="14">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12"/>
                </Border.StrokeShape>
                <HorizontalStackLayout Spacing="10">
                    <Label Text="⚠️" FontSize="16" VerticalOptions="Center"/>
                    <Label Text="{Binding ErrorMessage}" TextColor="{StaticResource AccentRed}" 
                           FontSize="14" VerticalOptions="Center"/>
                </HorizontalStackLayout>
            </Border>

            <!-- Username -->
            <Border Style="{StaticResource InputBorder}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12"/>
                </Border.StrokeShape>
                <HorizontalStackLayout Spacing="12">
                    <Label Text="👤" FontSize="18" VerticalOptions="Center" Opacity="0.6"/>
                    <Entry Text="{Binding Username}" 
                           Placeholder="Nume utilizator"
                           HorizontalOptions="FillAndExpand"
                           ReturnType="Next"/>
                </HorizontalStackLayout>
            </Border>

            <!-- Password -->
            <Border Style="{StaticResource InputBorder}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12"/>
                </Border.StrokeShape>
                <HorizontalStackLayout Spacing="12">
                    <Label Text="🔒" FontSize="18" VerticalOptions="Center" Opacity="0.6"/>
                    <Entry Text="{Binding Password}" 
                           Placeholder="Parolă"
                           IsPassword="True"
                           HorizontalOptions="FillAndExpand"
                           ReturnType="Done"/>
                </HorizontalStackLayout>
            </Border>

            <!-- Login Button -->
            <Button Text="Autentificare"
                    Command="{Binding LoginCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                    Style="{StaticResource PrimaryButton}"
                    Margin="0,8,0,0"/>

            <!-- Loading indicator -->
            <ActivityIndicator IsRunning="{Binding IsBusy}" 
                              IsVisible="{Binding IsBusy}"
                              HorizontalOptions="Center"/>

            <!-- Separator -->
            <Grid ColumnDefinitions="*, Auto, *" Margin="0,8">
                <BoxView Grid.Column="0" HeightRequest="1" 
                         BackgroundColor="{StaticResource BorderDefault}" 
                         VerticalOptions="Center"/>
                <Label Grid.Column="1" Text="sau" 
                       TextColor="{StaticResource TextMuted}" 
                       FontSize="12" Margin="12,0"/>
                <BoxView Grid.Column="2" HeightRequest="1" 
                         BackgroundColor="{StaticResource BorderDefault}" 
                         VerticalOptions="Center"/>
            </Grid>

            <!-- Register link -->
            <Button Text="Creează un cont nou"
                    Command="{Binding NavigateToRegisterCommand}"
                    Style="{StaticResource SecondaryButton}"/>
        </VerticalStackLayout>

        <BoxView Grid.Row="2"/>
    </Grid>
</ContentPage>
